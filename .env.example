# API Keys (optional for basic setup)
ANTHROPIC_API_KEY=your_key_here
PACER_API_KEY=your_key_here

# Database (optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# System Parameters
ETHICAL_COVERAGE_THRESHOLD=0.65
ANOMALY_SEVERITY_THRESHOLD=0.7
DECAY_RATE=0.95

# Processing
MAX_SIGNALS_PER_CYCLE=100
PROCESSING_INTERVAL_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/system.log